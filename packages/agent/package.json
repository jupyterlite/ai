{
  "name": "@jupyterlite/agent",
  "version": "0.18.0",
  "description": "AI agent implementation for Jupyter using AI SDK",
  "license": "BSD-3-Clause",
  "author": "JupyterLite Contributors",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*.{d.ts,js,js.map,json}",
    "src/**/*.{ts,tsx}"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jupyterlite/ai.git",
    "directory": "packages/agent"
  },
  "scripts": {
    "build": "echo 'Building @jupyterlite/agent' && tsc --sourceMap",
    "build:prod": "echo 'Building @jupyterlite/agent' && jlpm clean && tsc",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "sync:model-info": "node scripts/sync-model-info.mjs && prettier --write src/providers/generated-model-info.ts && eslint --fix src/providers/generated-model-info.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/coreutils": "^6.4.6",
    "@jupyterlab/rendermime": "^4.4.6",
    "@jupyterlab/services": "^7.4.6",
    "@lumino/coreutils": "^2.2.1",
    "@lumino/disposable": "^2.1.4",
    "@lumino/signaling": "^2.1.4",
    "ai": "^6.0.116",
    "jupyter-secrets-manager": "^0.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "rimraf": "^5.0.1",
    "typescript": "~5.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
